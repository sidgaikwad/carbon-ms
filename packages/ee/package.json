    "ai": "5.0.172",
    "cookie": "1.1.1",
    "dompurify": "3.4.0",
    "nanoid": "5.1.7",
    "react-pdf": "10.4.1",
    "sst": "4.6.9",
    "supabase": "2.84.5",
    "tsup": "8.5.1",
    "zod": "3.25.76"
