{
  "name": "@carbon/stripe",
  "dependencies": {
    "@carbon/auth": "*",
    "@carbon/database": "*",
    "@carbon/jobs": "*",
    "@carbon/kv": "*",
    "@carbon/lib": "*",
    "@supabase/supabase-js": "2.80.0",
    "stripe": "18.5.0"
  },
  "type": "module",
  "devDependencies": {
    "@carbon/config": "*",
    "@carbon/logger": "*",
    "@types/node": "20.19.39",
    "dotenv": "16.3.1",
    "rimraf": "5.0.10",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "zod": "3.25.76"
  },
  "exports": {
    "./stripe.server": "./src/stripe.server.ts"
