{
  "name": "@carbon/database",
  "devDependencies": {
    "@carbon/config": "*",
    "@supabase/supabase-js": "2.80.0",
    "@types/node": "20.19.39",
    "@types/uuid": "8.3.4",
    "dotenv": "16.3.1",
    "npm-run-all": "4.1.5",
    "rimraf": "5.0.10",
    "supabase": "2.89.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "uuid": "9.0.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./event": "./src/event.ts",
    "./ratelimit": "./src/ratelimit.ts",
    "./audit": "./src/audit.ts",
    "./audit.config": "./src/audit.config.ts",
    "./audit.types": "./src/audit.types.ts",
    "./swagger-docs-schema": "./src/swagger-docs-schema.ts"
  },
  "private": true,
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "db:diff": "supabase db diff",
    "db:function:new": "supabase functions new",
    "db:init": "supabase init",
    "db:kill": "supabase stop --no-backup",
    "db:migrate": "supabase migration up",
    "db:migrate:new": "supabase migration new",
    "db:seed": "tsx src/seed.ts",
    "db:seed:dev": "tsx src/seed-dev.ts",
    "db:setup": "supabase db reset",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:types": "supabase gen types typescript --local > src/types.ts",
    "deploy": "supabase link --project-ref $SUPABASE_PROJECT_ID && supabase db push",
    "lint": "biome lint --write ",
    "setup": "tsx src/seed.ts",
    "typecheck": "tsgo --noEmit"
  },
  "sideEffects": false,
  "version": "*",
  "dependencies": {
    "cookie": "1.1.1",
    "dompurify": "3.4.0",
    "kysely": "0.28.15",
    "kysely-supabase": "0.2.1",
    "nanoid": "5.1.7",
    "pg": "8.20.0",
    "react-pdf": "10.4.1",
    "sst": "4.6.9"
  }
}
